{
  "id": "notifications",
  "name": "Notifications",
  "version": "0.1.0",
  "category": "feature",
  "authors": [
    "Bias"
  ],
  "dependencies": [
    "core",
    "content",
    "users"
  ],
  "optional_dependencies": [],
  "django": {
    "app_config": "bias_ext_notifications.backend.apps.NotificationsExtensionConfig",
    "app_label": "notifications",
    "migration_module": "bias_ext_notifications.backend.django_migrations"
  },
  "backend": {
    "entry": "bias_ext_notifications.backend.ext"
  },
  "extra": {
    "auto_install": true,
    "auto_enable": true
  },
  "performance_contracts": [
    {
      "name": "notification_pagination_indexes",
      "message": "notification list has pagination and required indexes.",
      "required_indexes": [
        [
          "user"
        ],
        [
          "user",
          "is_read"
        ],
        [
          "user",
          "is_deleted"
        ],
        [
          "created_at"
        ],
        [
          "subject_type",
          "subject_id"
        ]
      ],
      "missing_indexes": [],
      "pagination": "page/limit normalized by PaginationService"
    }
  ],
  "security": {
    "capabilities_notice": "Notification delivery extension; stores user notification records and exposes notification preferences and views."
  }
}
